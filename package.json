{
  "name": "allow-methods",
  "version": "7.1.0",
  "type": "module",
  "description": "Express/connect middleware to handle 405 errors",
  "keywords": [
    "405",
    "connect",
    "error",
    "express",
    "http",
    "middleware"
  ],
  "author": "Rowan Manning (https://rowanmanning.com/)",
  "repository": {
    "type": "git",
    "url": "https://github.com/rowanmanning/allow-methods.git"
  },
  "homepage": "https://github.com/rowanmanning/allow-methods",
  "bugs": "https://github.com/rowanmanning/allow-methods/issues",
  "license": "MIT",
  "engines": {
    "node": "22.x || 24.x"
  },
  "scripts": {
    "verify": "npm run verify:biome && npm run verify:types",
    "verify:biome": "biome check",
    "verify:types": "tsc --project ./jsconfig.json",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node --test --experimental-test-coverage --test-coverage-branches=100 --test-coverage-functions=100 --test-coverage-lines=100 test/unit/**/*.test.js",
    "test:integration": "node --test test/integration/**/*.test.js",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@rowanmanning/biome-config": "^3.0.1",
    "@types/express": "^5.0.0",
    "express4": "npm:express@^4.21.0",
    "express5": "npm:express@^5.0.0",
    "husky": "^9.0.7",
    "typescript": "^5.5.2"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  }
}
